SECRET_KEY=replace-with-a-secure-secret
DEBUG=False

# Comma-separated hosts and origins for Render/custom domains.
ALLOWED_HOSTS=your-render-service.onrender.com,yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://your-render-service.onrender.com,https://yourdomain.com,https://www.yourdomain.com

# Supabase Postgres connection string.
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?sslmode=require

# SMTP settings (Render Environment variables).
# Example for Gmail SMTP:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-smtp-user@example.com
EMAIL_HOST_PASSWORD=your-smtp-app-password
DEFAULT_FROM_EMAIL=CourtesyChain <your-smtp-user@example.com>
SERVER_EMAIL=your-smtp-user@example.com
EMAIL_TIMEOUT=30
CONTACT_EMAIL_RECIPIENT=your-inbox@example.com

# Optional: set only when frontend is served from a different domain.
VITE_API_BASE_URL=
